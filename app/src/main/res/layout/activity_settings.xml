<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_tap_count_title"
            android:textSize="18sp"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/radioGroupTapCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/radio2Taps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tap_count_2" />

            <RadioButton
                android:id="@+id/radio3Taps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:text="@string/tap_count_3" />
        </RadioGroup>

        <TextView
            android:id="@+id/textShakeSensitivityValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:layout_marginBottom="8dp" />

        <SeekBar
            android:id="@+id/seekBarShakeSensitivity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="25"
            android:layout_marginBottom="24dp" />

        <Switch
            android:id="@+id/switchHomeScreenOnly"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_home_screen_only"
            android:layout_marginBottom="16dp" />

        <Switch
            android:id="@+id/switchExcludeCalls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_exclude_calls"
            android:layout_marginBottom="16dp" />

        <Switch
            android:id="@+id/switchExcludeCamera"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_exclude_camera"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_volume_streams_title"
            android:textSize="18sp"
            android:layout_marginBottom="8dp" />

        <Switch
            android:id="@+id/switchStreamRing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/stream_ring" />

        <Switch
            android:id="@+id/switchStreamNotification"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/stream_notification" />

        <Switch
            android:id="@+id/switchStreamAlarm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/stream_alarm" />

        <Switch
            android:id="@+id/switchStreamMedia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/stream_media" />

        <Switch
            android:id="@+id/switchStreamCall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/stream_call"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_language_title"
            android:textSize="18sp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnLanguageEnglish"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/language_english" />

            <Button
                android:id="@+id/btnLanguageHindi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/language_hindi" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>